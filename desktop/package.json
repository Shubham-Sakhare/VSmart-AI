{
  "name": "vsmart-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron dist-electron/main.js\"",
    "build": "tsc -p tsconfig.app.json && vite build && tsc -p tsconfig.electron.json && tsc -p tsconfig.preload.json",
    "electron": "electron dist-electron/main.js",
    "electron:build": "tsc -p tsconfig.electron.json",
    "lint": "eslint .",
    "postinstall": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/orbitron": "^5.2.8",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.42.2",
    "loudness": "^0.4.2",
    "lucide-react": "^1.24.0",
    "node-machine-id": "^1.1.12",
    "open": "^11.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "systeminformation": "^5.31.17",
    "three": "^0.185.1",
    "vosk-koffi": "^1.1.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "electron": "^40.10.6",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "wait-on": "^9.0.10"
  }
}
